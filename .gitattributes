# Enforce LF line endings for all text files
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf

# Documentation
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
.env* text eol=lf
