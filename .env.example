# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Obsidian Vault path (absolute path)
VAULT_PATH=C:/Users/yourname/ObsidianVault

# Allowed Telegram user IDs (comma-separated, leave empty to allow all)
ALLOWED_USER_IDS=

# Enable Simplified → Traditional Chinese translation (true/false)
ENABLE_TRANSLATION=true

# Max external URLs to fetch metadata per post (default: 5)
MAX_LINKED_URLS=5

# Save downloaded videos to vault attachments (default: false)
# Videos are still temporarily downloaded for transcription but not kept in vault
SAVE_VIDEOS=false

# Preferred LLM CLI provider: claude / codex / opencode (optional)
LLM_PROVIDER=

# ── oMLX 本地推理 (Apple Silicon) ──────────────────────────────────
# 啟用後優先使用本地 oMLX，失敗時自動降級到 OpenCode CLI → DDG Chat
OMLX_ENABLED=false
OMLX_BASE_URL=http://localhost:8000/v1
OMLX_API_KEY=

# 模型對應（留空使用預設值）
# OMLX_MODEL_FLASH=MLX-Qwen3.5-4B-Claude-4.6-Opus-Reasoning-Distilled-4bit
# OMLX_MODEL_STANDARD=Qwen3.5-9B-MLX-4bit
# OMLX_MODEL_DEEP=Qwen3.5-27B-4bit
# OMLX_MODEL_VISION=Qwen2.5-VL-7B-Instruct-4bit
