# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Obsidian Vault path (absolute path)
VAULT_PATH=/Users/yourname/ObsidianVault

# Allowed Telegram user IDs (comma-separated, leave empty to allow all)
ALLOWED_USER_IDS=

# Enable Simplified → Traditional Chinese translation (true/false)
ENABLE_TRANSLATION=true

# Max external URLs to fetch metadata per post (default: 5)
MAX_LINKED_URLS=5

# Save downloaded videos to vault attachments (default: false)
# Videos are still temporarily downloaded for transcription but not kept in vault
SAVE_VIDEOS=false

# Preferred LLM CLI provider: claude / codex / opencode (optional)
LLM_PROVIDER=

# oMLX local inference (optional, takes priority over opencode CLI if set)
# Requires oMLX running on your Mac: https://github.com/nicfab/omlx
OMLX_BASE_URL=http://localhost:10240/v1
OMLX_MODEL=
